# DigitalOcean Gradient AI agent credentials
DIGITAL_OCEAN_ENDPOINT=https://your-agent-id.agents.do-ai.run
DIGITAL_OCEAN_AGENT_ACCESS_KEY=your_agent_access_key

# Memori Cloud (recommended for long-term conversation memory)
MEMORI_API_KEY=your_memori_api_key

# Optional stable identity and SQLite location
APP_USER_ID=your-user-id
DATABASE_PATH=.data/blog_agent.db
